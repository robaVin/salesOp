# Sales Canvas backend env
PORT=3001
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sales_canvas
DASHBOARD_ORIGIN=http://localhost:5173

# AI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Stripe (test mode only — never production keys)
STRIPE_TEST_KEY=sk_test_...

# Workspace defaults (single workspace V1)
DEFAULT_WORKSPACE_SLUG=demo
DEFAULT_USER_NAME=Sales Manager

# Auth — generate strong values for production
SESSION_SECRET=dev-insecure-change-me-in-production-32-chars-min
SESSION_COOKIE_NAME=sc_session
SESSION_TTL_DAYS=7

# Google OAuth — optional. Leave blank to hide "Sign in with Google".
# Setup: console.cloud.google.com → APIs & Services → Credentials →
#   Create Credentials → OAuth client ID → Web application.
# Authorized redirect URI must match GOOGLE_OAUTH_REDIRECT_URI exactly.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5173/api/auth/google/callback

# Path the user lands on after sign-in. Must be a relative path.
POST_LOGIN_REDIRECT=/

# DEV ONLY — let the Chrome extension hit /api/capture without an API token.
# Captures route into the configured user's workspace. Refused if NODE_ENV=production.
DEV_CAPTURE_NO_AUTH=false
DEV_CAPTURE_USER_EMAIL=
